# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Set to 'true' only in development (disables HTTPS-only session cookies)
DEV_MODE=false

# Redis URL — default works with docker-compose
REDIS_URL=redis://redis:6379

# Host port the app listens on (default: 5001)
PORT=5001
